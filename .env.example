# Sentimental Logic — Umgebungsvariablen
# Kopiere diese Datei zu .env.local und fülle alle Werte aus
# NIEMALS .env.local in Git committen

# ── SUPABASE ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── TESTDATEN IN DER LIVE-UMGEBUNG ────────────────────────────
# Die Bereinigung löscht ausschließlich technisch markierte Testdatensätze.
TEST_DATA_CLEANUP_ENABLED=false
TEST_SUPABASE_PROJECT_REF=
TEST_DATA_GUARD_ID=
# Mindestens 32 zufällige Zeichen; ausschließlich als Server-/CI-Secret speichern.
# Wird zusätzlich als bewusst eingegebenes Steuerungs-Token im Testdashboard verwendet.
TEST_DATA_CLEANUP_TOKEN=

